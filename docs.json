{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FoN API Documentation",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "favicon": "/images/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/uploads",
              "concepts/voting",
              "concepts/tags"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "api-reference/auth/register-login",
              "api-reference/auth/check-status",
              "api-reference/auth/logout",
              "api-reference/auth/password-management",
              "api-reference/auth/mfa",
              "api-reference/auth/api-tokens",
              "api-reference/auth/oauth"
            ]
          },
          {
            "group": "Uploads",
            "pages": [
              "api-reference/uploads/create",
              "api-reference/uploads/get",
              "api-reference/uploads/list",
              "api-reference/uploads/delete",
              "api-reference/uploads/privacy"
            ]
          },
          {
            "group": "Voting",
            "pages": [
              "api-reference/voting/submit-vote",
              "api-reference/voting/get-votes",
              "api-reference/voting/anonymous-voting"
            ]
          },
          {
            "group": "Tags",
            "pages": [
              "api-reference/tags/list",
              "api-reference/tags/search",
              "api-reference/tags/upload-tags"
            ]
          },
          {
            "group": "Media",
            "pages": [
              "api-reference/media/images",
              "api-reference/media/thumbnails"
            ]
          },
          {
            "group": "User",
            "pages": [
              "api-reference/user/profile",
              "api-reference/user/uploads"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Fucks or Not",
        "href": "https://fucksornot.com"
      }
    ]
  },
  "api": {
    "baseUrl": "https://fucksornot.com"
  },
  "background": {
    "decoration": "gradient"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Roboto"
  },
  "styling": {
    "eyebrows": "section"
  },
  "icons": {
    "library": "fontawesome"
  }
}
