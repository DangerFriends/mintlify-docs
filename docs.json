{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FoN API Documentation",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/uploads",
              "concepts/voting",
              "concepts/tags"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "api-reference/auth/register-login",
              "api-reference/auth/check-status",
              "api-reference/auth/logout",
              "api-reference/auth/password-management",
              "api-reference/auth/mfa",
              "api-reference/auth/api-tokens",
              "api-reference/auth/oauth"
            ]
          },
          {
            "group": "Uploads",
            "pages": [
              "api-reference/uploads/create",
              "api-reference/uploads/get",
              "api-reference/uploads/list",
              "api-reference/uploads/delete",
              "api-reference/uploads/privacy"
            ]
          },
          {
            "group": "Voting",
            "pages": [
              "api-reference/voting/submit-vote",
              "api-reference/voting/get-votes",
              "api-reference/voting/anonymous-voting"
            ]
          },
          {
            "group": "Tags",
            "pages": [
              "api-reference/tags/list",
              "api-reference/tags/search",
              "api-reference/tags/upload-tags"
            ]
          },
          {
            "group": "Media",
            "pages": [
              "api-reference/media/images",
              "api-reference/media/thumbnails"
            ]
          },
          {
            "group": "User",
            "pages": [
              "api-reference/user/profile",
              "api-reference/user/uploads"
            ]
          },
          {
            "group": "Admin",
            "pages": [
              "api-reference/admin/overview",
              "api-reference/admin/users",
              "api-reference/admin/uploads",
              "api-reference/admin/moderation"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Status",
          "href": "https://status.fon.app",
          "icon": "signal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@fon.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://fon.app/dashboard"
    }
  },
  "api": {
    "baseUrl": "https://api.fon.app",
    "auth": {
      "method": "bearer"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/fonapp",
      "github": "https://github.com/fon"
    }
  }
}
